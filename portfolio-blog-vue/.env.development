# 开发时通过 Vite 代理转发到 RuoYi（见 vite.config.ts），前缀 /api 会 rewrite 掉
VITE_API_BASE=/api

# 与后端 api-decrypt.privateKey 成对的公钥（当前本地后端私钥对应此值）
VITE_AUTH_RSA_PUBLIC_KEY=MFwwDQYJKoZIhvcNAQEBBQADSwAwSAJBAKoR8mX0rGKLqzcWmOzbfj64K8ZIgOdHnzkXSOVOZbFu/TJhZ7rFAN+eaGkl3C4buccQd/EjEsj9ir7ijT7h96MCAwEAAQ==

# 若本地将 api-decrypt.enabled 设为 false，可改为 VITE_AUTH_ENCRYPT=false，并省略 RSA 公钥
# VITE_AUTH_ENCRYPT=false

# 内置默认 client / 租户，与脚本 sys_client 插入值一致；多租户环境按需修改
VITE_RUOYI_CLIENT_ID=e5cd7e4891bf95d1d19206ce24a7b32e
VITE_RUOYI_TENANT_ID=000000
